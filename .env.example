# ---------------------------------------------------------------------------
# Booking Tool — environment variables
# Copy this file to server/.env and fill in the values.
# ---------------------------------------------------------------------------

# --- Server ---
PORT=4000
NODE_ENV=development

# Origin allowed by CORS (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
# Full Postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/booking_tool

# --- Auth ---
# Secret used to sign admin session JWTs. Use a long random string in production.
JWT_SECRET=dev-only-change-me
# How long an admin session lasts.
JWT_EXPIRES_IN=7d

# --- Seed admin (demo login, documented in the README) ---
SEED_ADMIN_EMAIL=admin@demo.test
SEED_ADMIN_PASSWORD=demo1234

# --- Business settings ---
# Single business timezone (IANA name). Data is stored in UTC, displayed local.
BUSINESS_TIMEZONE=America/New_York

# --- Email (wired up later) ---
# Resend API key, or leave blank to log emails to the console in dev.
RESEND_API_KEY=
EMAIL_FROM="Booking Tool <bookings@demo.test>"
